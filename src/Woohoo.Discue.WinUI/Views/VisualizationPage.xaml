<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.VisualizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Woohoo.Discue.Views"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="VisualizationPage_Title"
            FontSize="40"
            FontWeight="SemiBold" />

        <views:SignalPlotControl
            x:Name="SignalControl"
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" />
    </Grid>
</Page>
