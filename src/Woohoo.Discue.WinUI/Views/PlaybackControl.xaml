<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Woohoo.Discue.Views.PlaybackControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Woohoo.Discue.Views"
    mc:Ignorable="d">

    <Grid>
        <Border>
            <Grid Margin="0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Margin="20,0"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.CurrentTrackPositionAsText, Mode=OneWay}" />
                    <Slider
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsEnabled="{x:Bind ViewModel.IsNowPlayingEnabled, Mode=OneWay}"
                        IsTapEnabled="False"
                        Maximum="1"
                        Minimum="0"
                        Value="{x:Bind ViewModel.CurrentTrackPositionAsDouble, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="2"
                        Margin="20,0"
                        VerticalAlignment="Center"
                        Text="{x:Bind ViewModel.CurrentTrackDurationAsText, Mode=OneWay}" />
                </Grid>
                <Grid
                    Grid.Row="1"
                    MinHeight="85"
                    Margin="10"
                    ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition MaxWidth="400" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Uid="PlaybackControl_NowPlayingButton"
                        Grid.Column="0"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Click="MediaInfoButton_Click"
                        Visibility="{x:Bind ViewModel.IsNowPlayingEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ToolTipService.ToolTip>
                            <StackPanel Orientation="Vertical">
                                <TextBlock x:Uid="PlaybackControl_NowPlaying" Margin="0,5" />
                                <TextBlock
                                    Margin="0,5"
                                    Text="{x:Bind ViewModel.CurrentTrackTitle, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Margin="0,5"
                                    Text="{x:Bind ViewModel.FullAlbumTitle, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </ToolTipService.ToolTip>
                        <StackPanel Orientation="Horizontal">
                            <Border
                                Width="72"
                                Height="72"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{ThemeResource ControlCornerRadius}">
                                <Grid>
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="32"
                                        Glyph="&#xEC4F;"
                                        Visibility="{x:Bind ViewModel.HasAlbumArt, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true, Mode=OneWay}" />
                                    <Image
                                        Width="72"
                                        Height="72"
                                        Source="{x:Bind ViewModel.AlbumArt, Mode=OneWay}"
                                        Visibility="{x:Bind ViewModel.HasAlbumArt, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                </Grid>
                            </Border>
                            <StackPanel
                                Margin="20,0"
                                VerticalAlignment="Center"
                                Orientation="Vertical">
                                <TextBlock
                                    Margin="0,5"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind ViewModel.CurrentTrackTitle, Mode=OneWay}" />
                                <TextBlock FontSize="14" Text="{x:Bind ViewModel.FullAlbumTitle, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <StackPanel
                        x:Name="PlaybackButtons"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <StackPanel.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{ThemeResource SubtleFillColorSecondary}" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="{ThemeResource SubtleFillColorTertiary}" />
                        </StackPanel.Resources>
                        <Button
                            x:Uid="PlaybackControl_PreviousTrackButton"
                            Margin="5"
                            HorizontalAlignment="Center"
                            BorderThickness="0"
                            Click="PreviousTrackButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsPreviousEnabled, Mode=OneWay}">
                            <FontIcon Margin="0,5" Glyph="&#xE892;" />
                        </Button>
                        <Button
                            x:Uid="PlaybackControl_SeekBackwardButton"
                            Margin="5"
                            BorderThickness="0"
                            Click="SeekBackwardButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsSeekBackwardEnabled, Mode=OneWay}">
                            <FontIcon Margin="0,5" Glyph="&#xEB9E;" />
                        </Button>
                        <Button
                            x:Uid="PlaybackControl_PlayPauseButton"
                            Margin="5"
                            BorderThickness="0"
                            Click="PlayPauseButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsPlayPauseEnabled, Mode=OneWay}"
                            ToolTipService.ToolTip="Play / Pause">
                            <FontIcon
                                Margin="0,5"
                                FontSize="40"
                                Glyph="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}" />
                        </Button>
                        <Button
                            x:Uid="PlaybackControl_SeekForwardButton"
                            Margin="5"
                            BorderThickness="0"
                            Click="SeekForwardButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsSeekForwardEnabled, Mode=OneWay}">
                            <FontIcon Margin="0,5" Glyph="&#xEB9D;" />
                        </Button>
                        <Button
                            x:Uid="PlaybackControl_NextTrackButton"
                            Margin="5"
                            BorderThickness="0"
                            Click="NextTrackButton_Click"
                            IsEnabled="{x:Bind ViewModel.IsNextEnabled, Mode=OneWay}">
                            <FontIcon Margin="0,5" Glyph="&#xE893;" />
                        </Button>
                    </StackPanel>

                    <Grid
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Visibility="{x:Bind ViewModel.IsNowPlayingEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Button
                            x:Name="AmplitudeButton"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="0"
                            Click="AmplitudeButton_Click">
                            <views:SignalPlotControl
                                x:Name="SignalControl"
                                Width="200"
                                Height="72"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{ThemeResource ControlCornerRadius}" />
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AmplitudeButton.Visibility" Value="Visible" />
                        <Setter Target="PlaybackButtons.HorizontalAlignment" Value="Center" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState>
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="AmplitudeButton.Visibility" Value="Collapsed" />
                        <Setter Target="PlaybackButtons.HorizontalAlignment" Value="Right" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</UserControl>
