<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.PlaylistPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lct="using:Woohoo.Discue.Converters"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Woohoo.Discue.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="PlaylistPage_Title"
            Grid.Row="0"
            FontSize="40"
            FontWeight="SemiBold" />

        <StackPanel
            Grid.Row="1"
            Orientation="Vertical"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
            <TextBlock x:Uid="PlaylistPage_Empty" />
        </StackPanel>

        <ListView
            Grid.Row="1"
            Margin="0,0,0,10"
            ui:ListViewExtensions.AlternateColor="{ThemeResource LayerFillColorDefaultBrush}"
            ui:ScrollViewerExtensions.VerticalScrollBarMargin="0, 0, -8, 0"
            ItemsSource="{x:Bind ViewModel.Items}"
            Visibility="{x:Bind ViewModel.HasItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:PlaylistItemViewModel">
                    <Grid
                        Margin="5,0"
                        ColumnSpacing="10"
                        DoubleTapped="Grid_DoubleTapped">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <Grid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem x:Uid="PlaylistPage_PlayMenuItem" Command="{x:Bind PlayCommand, Mode=OneWay}" />
                            </MenuFlyout>
                        </Grid.ContextFlyout>
                        <FontIcon
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Glyph="&#xE8D6;"
                            Visibility="{x:Bind IsActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock
                            x:Name="trackNumberTextBlock"
                            Grid.Column="1"
                            Foreground="{x:Bind local:PlaylistPage.GetPlaylistTrackBrush(IsActive), Mode=OneWay}"
                            Text="{x:Bind TrackNumber, Mode=OneWay, Converter={StaticResource StringFormatConverter}, ConverterParameter=' {0:00}'}" />
                        <TextBlock
                            x:Name="trackTitleTextBlock"
                            Grid.Column="2"
                            Foreground="{x:Bind local:PlaylistPage.GetPlaylistTrackBrush(IsActive), Mode=OneWay}"
                            Text="{x:Bind TrackTitle, Mode=OneWay}" />
                        <TextBlock
                            x:Name="trackDurationTextBlock"
                            Grid.Column="3"
                            Foreground="{x:Bind local:PlaylistPage.GetPlaylistTrackBrush(IsActive), Mode=OneWay}"
                            HorizontalTextAlignment="Right"
                            Text="{x:Bind TrackSize, Converter={StaticResource PositionToLabelConverter}, Mode=OneWay}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
