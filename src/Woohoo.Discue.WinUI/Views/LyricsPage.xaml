<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.LyricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lct="using:Woohoo.Discue.Converters"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Woohoo.Discue.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="LyricsPage_Title"
            Grid.Row="0"
            FontSize="40"
            FontWeight="SemiBold" />

        <StackPanel
            Grid.Row="1"
            Orientation="Vertical"
            Visibility="{x:Bind ViewModel.HasLyrics, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">
            <TextBlock x:Uid="LyricsPage_NoLyricsAvailable" />
        </StackPanel>

        <ScrollViewer
            x:Name="LyricsItemsScrollViewer"
            Grid.Row="1"
            Margin="0,0,0,20"
            Visibility="{x:Bind ViewModel.HasLyrics, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsRepeater x:Name="LyricsItemsRepeater" ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:LyricsLineViewModel">
                        <TextBlock
                            Margin="0,2"
                            HorizontalAlignment="Left"
                            FontStyle="{x:Bind local:LyricsPage.GetLyricFontStyle(IsCurrent), Mode=OneWay}"
                            FontWeight="{x:Bind local:LyricsPage.GetLyricFontWeight(IsCurrent), Mode=OneWay}"
                            Foreground="{x:Bind local:LyricsPage.GetLyricBrush(IsCurrent), Mode=OneWay}"
                            Text="{x:Bind Text}"
                            TextWrapping="WrapWholeWords" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </ScrollViewer>
    </Grid>
</Page>
