<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:CommunityToolkit.WinUI"
    xmlns:ctcontrols="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lclviewmodels="using:Woohoo.Discue.ViewModels"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="SettingsPage_Title"
            FontSize="40"
            FontWeight="SemiBold" />

        <ScrollViewer Grid.Row="1">
            <Grid>
                <StackPanel Margin="0,0,50,0" Spacing="{StaticResource SettingsCardSpacing}">
                    <TextBlock x:Uid="SettingsPage_Appearance" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                    <ctcontrols:SettingsCard x:Uid="SettingsPage_AutoScrollLyrics" HeaderIcon="Tag">
                        <StackPanel Margin="{StaticResource XSmallTopMargin}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.LyricsAutoScroll, Mode=TwoWay}" />
                        </StackPanel>
                    </ctcontrols:SettingsCard>

                    <TextBlock x:Uid="SettingsPage_MediaInfo" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                    <ctcontrols:SettingsCard x:Uid="SettingsPage_LookupMetadataOnline" HeaderIcon="Tag">
                        <StackPanel Margin="{StaticResource XSmallTopMargin}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.QueryMetadataOnline, Mode=TwoWay}" />
                        </StackPanel>
                    </ctcontrols:SettingsCard>

                    <ctcontrols:SettingsCard x:Uid="SettingsPage_LookupLyricsOnline" HeaderIcon="{ct:FontIcon Glyph=&#xED1E;}">
                        <StackPanel Margin="{StaticResource XSmallTopMargin}">
                            <ToggleSwitch IsOn="{x:Bind ViewModel.QueryLyricsOnline, Mode=TwoWay}" />
                        </StackPanel>
                    </ctcontrols:SettingsCard>

                    <TextBlock x:Uid="SettingsPage_AudioEngineInfo" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                    <ctcontrols:SettingsExpander x:Uid="SettingsPage_AudioEngineExpander" HeaderIcon="{ct:FontIcon Glyph=&#xEEA1;}">
                        <ctcontrols:SettingsExpander.Items>
                            <ctcontrols:SettingsCard ContentAlignment="Left">
                                <StackPanel Margin="{StaticResource XSmallTopMargin}">
                                    <RadioButton
                                        x:Uid="Settings_AudioEngine_Wmp"
                                        Command="{x:Bind ViewModel.SwitchAudioEngineCommand, Mode=OneWay}"
                                        GroupName="AudioEngine"
                                        IsChecked="{x:Bind ViewModel.AudioEngine, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=WindowsMediaPlayer, Mode=OneWay}">
                                        <RadioButton.CommandParameter>
                                            <lclviewmodels:AudioEngineType>WindowsMediaPlayer</lclviewmodels:AudioEngineType>
                                        </RadioButton.CommandParameter>
                                    </RadioButton>
                                    <RadioButton
                                        x:Uid="Settings_AudioEngine_Sdl3"
                                        Command="{x:Bind ViewModel.SwitchAudioEngineCommand, Mode=OneWay}"
                                        GroupName="AudioEngine"
                                        IsChecked="{x:Bind ViewModel.AudioEngine, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Sdl3, Mode=OneWay}">
                                        <RadioButton.CommandParameter>
                                            <lclviewmodels:AudioEngineType>Sdl3</lclviewmodels:AudioEngineType>
                                        </RadioButton.CommandParameter>
                                    </RadioButton>
                                </StackPanel>
                            </ctcontrols:SettingsCard>
                        </ctcontrols:SettingsExpander.Items>
                        <TextBlock Text="{x:Bind ViewModel.AudioEngine, Converter={StaticResource AudioEngineToTextConverter}, Mode=OneWay}" />
                    </ctcontrols:SettingsExpander>

                    <Grid Visibility="{x:Bind ViewModel.AudioEngineRestartRequired, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}">
                        <InfoBar
                            x:Uid="SettingsPage_AudioEngineRestartRequired"
                            Margin="{StaticResource SmallTopBottomMargin}"
                            IsOpen="{x:Bind ViewModel.AudioEngineRestartRequired, Mode=TwoWay}"
                            Severity="Warning">
                            <InfoBar.ActionButton>
                                <Button x:Uid="SettingsPage_RestartButton" Command="{x:Bind ViewModel.RestartCommand, Mode=OneWay}" />
                            </InfoBar.ActionButton>
                        </InfoBar>
                    </Grid>

                    <TextBlock x:Uid="SettingsPage_About" Style="{StaticResource SettingsSectionHeaderTextBlockStyle}" />

                    <ctcontrols:SettingsExpander x:Uid="SettingsPage_AboutExpander" HeaderIcon="{ct:FontIcon Glyph=&#xE946;}">

                        <TextBlock Style="{ThemeResource BodyTextBlockStyle}" Text="{x:Bind ViewModel.AboutInfo.AppVersion, Mode=OneWay}" />

                        <ctcontrols:SettingsExpander.Items>

                            <ctcontrols:SettingsCard ContentAlignment="Left">
                                <Grid ColumnSpacing="24">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutFramework"
                                        Grid.Row="0"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutProcessArchitecture"
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutRuntimeIdentifier"
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutOperatingSystem"
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutWindowsRuntime"
                                        Grid.Row="4"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutWindowsSdk"
                                        Grid.Row="5"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />
                                    <TextBlock
                                        x:Uid="SettingsPage_AboutAudioEngine"
                                        Grid.Row="6"
                                        Grid.Column="0"
                                        Style="{StaticResource SettingsCardInfoName}" />

                                    <TextBlock
                                        Grid.Row="0"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.DotNetFramework, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.ProcessArchitecture, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.RuntimeIdentifier, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.OperatingSystem, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="4"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.WindowsRuntime, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="5"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AboutInfo.WindowsSdk, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Row="6"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsCardInfoValue}"
                                        Text="{x:Bind ViewModel.AudioEngineDisplayName, Mode=OneWay}" />
                                </Grid>
                            </ctcontrols:SettingsCard>

                            <ctcontrols:SettingsCard ContentAlignment="Left">
                                <StackPanel Margin="{StaticResource XSmallTopMargin}">
                                    <HyperlinkButton x:Uid="SettingsPage_LicenseTermsLink" Margin="{StaticResource SettingsPageHyperlinkButtonMargin}" />
                                </StackPanel>
                            </ctcontrols:SettingsCard>

                        </ctcontrols:SettingsExpander.Items>
                    </ctcontrols:SettingsExpander>

                    <HyperlinkButton x:Uid="SettingsPage_SendFeedback" Margin="{StaticResource XSmallTopMargin}" />

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
