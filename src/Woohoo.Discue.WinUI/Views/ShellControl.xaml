<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Woohoo.Discue.Views.ShellControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:CommunityToolkit.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Woohoo.Discue.Helpers"
    xmlns:local="using:Woohoo.Discue"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Woohoo.Discue.Views"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="titleBar"
            x:Uid="MainWindow_TitleBar"
            ActualThemeChanged="TitleBar_ActualThemeChanged"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="True"
            Loaded="TitleBar_Loaded"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/Tiles/app-logo.ico" />
            </TitleBar.IconSource>
        </TitleBar>
        <NavigationView
            x:Name="navView"
            Grid.Row="1"
            Background="Transparent"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsPaneVisible="True"
            IsSettingsVisible="True"
            SelectedItem="{x:Bind NavigationSelectedItem, Mode=OneWay}">
            <NavigationView.Resources>
                <!--  Makes the border invisible  -->
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0,0,0,0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0,0,0,0</CornerRadius>

                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </NavigationView.Resources>
            <NavigationView.HeaderTemplate>
                <DataTemplate>
                    <Grid Margin="0,-10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Grid
                            x:Name="pageTitle"
                            Height="44"
                            VerticalAlignment="Top"
                            Background="Transparent">
                            <TextBlock
                                x:Name="title"
                                VerticalAlignment="Center"
                                FontSize="24"
                                Style="{StaticResource TitleTextBlockStyle}"
                                Text="{Binding}" />
                        </Grid>
                    </Grid>
                </DataTemplate>
            </NavigationView.HeaderTemplate>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Uid="MainWindow_Home"
                    helpers:NavigationHelper.NavigateTo="Woohoo.Discue.ViewModels.HomeViewModel"
                    Icon="Home" />
                <NavigationViewItem
                    x:Uid="MainWindow_NowPlaying"
                    helpers:NavigationHelper.NavigateTo="Woohoo.Discue.ViewModels.NowPlayingViewModel"
                    Icon="Audio"
                    Visibility="{x:Bind ViewModel.IsAlbumLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <NavigationViewItem
                    x:Uid="MainWindow_Visualization"
                    helpers:NavigationHelper.NavigateTo="Woohoo.Discue.ViewModels.VisualizationViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE9D2;}"
                    Visibility="{x:Bind ViewModel.IsAlbumLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <NavigationViewItem
                    x:Uid="MainWindow_Lyrics"
                    helpers:NavigationHelper.NavigateTo="Woohoo.Discue.ViewModels.LyricsViewModel"
                    Icon="{ct:FontIcon Glyph=&#xED1E;}"
                    Visibility="{x:Bind ViewModel.IsAlbumLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                <NavigationViewItem
                    x:Uid="MainWindow_Playlist"
                    helpers:NavigationHelper.NavigateTo="Woohoo.Discue.ViewModels.PlaylistViewModel"
                    Icon="{ct:FontIcon Glyph=&#xE93C;}"
                    Visibility="{x:Bind ViewModel.IsAlbumLoaded, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
            </NavigationView.MenuItems>
            <Frame x:Name="navFrame" Background="Transparent" />
        </NavigationView>
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border
                Grid.Row="0"
                Height="1"
                HorizontalAlignment="Stretch"
                BorderBrush="{ThemeResource ListBoxBorderThemeBrush}"
                BorderThickness="1" />
            <views:PlaybackControl Grid.Row="1" />
        </Grid>
    </Grid>

</UserControl>
