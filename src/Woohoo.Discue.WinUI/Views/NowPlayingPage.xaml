<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.NowPlayingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Woohoo.Discue.Views"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="NowPlayingPage_Title"
            FontSize="40"
            FontWeight="SemiBold" />

        <Grid
            Grid.Row="1"
            VerticalAlignment="Center"
            Visibility="{x:Bind ViewModel.IsNowPlayingEnabled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid
                Grid.Row="0"
                Grid.Column="0"
                VerticalAlignment="Top">
                <Grid x:Name="artShadowCastGrid" />
                <Border
                    Width="248"
                    Height="248"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="{ThemeResource OverlayCornerRadius}"
                    Loaded="Border_Loaded"
                    Translation="0,0,35">
                    <Border.Shadow>
                        <ThemeShadow x:Name="artShadow" />
                    </Border.Shadow>
                    <Grid>
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="72"
                            Glyph="&#xEC4F;"
                            Visibility="{x:Bind ViewModel.AlbumArt.HasImage, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true, Mode=OneWay}" />
                        <Image
                            Width="256"
                            Height="256"
                            Margin="-4"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Source="{x:Bind ViewModel.AlbumArt.LocalImage, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.AlbumArt.HasImage, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                    </Grid>
                </Border>
            </Grid>
            <StackPanel
                Grid.Row="0"
                Grid.Column="1"
                VerticalAlignment="Top"
                Orientation="Vertical">
                <TextBlock
                    Margin="20,0,20,20"
                    Style="{StaticResource TitleLargeTextBlockStyle}"
                    Text="{x:Bind ViewModel.TrackTitle, Mode=OneWay}" />
                <TextBlock
                    Margin="20,0,20,20"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    Text="{x:Bind ViewModel.FullAlbumTitle, Mode=OneWay}" />
                <TextBlock
                    Margin="20,0,20,20"
                    FontSize="{StaticResource BodyTextBlockFontSize}"
                    Text="{x:Bind ViewModel.CurrentLyric, Mode=OneWay}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
