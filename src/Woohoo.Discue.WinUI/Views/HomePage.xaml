<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Woohoo.Discue.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Woohoo.Discue.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="using:System"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Woohoo.Discue.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="40,0" RowSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Uid="HomePage_Title"
            Grid.Row="0"
            FontSize="40"
            FontWeight="SemiBold" />

        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Visibility="{x:Bind ViewModel.HasRecentDiscs, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true}">

            <Image
                Width="250"
                Margin="30,0"
                Source="/Assets/Meet.png" />

            <StackPanel VerticalAlignment="Center" Orientation="Vertical">
                <TextBlock
                    x:Uid="HomePage_StarterHeader"
                    Margin="10,0"
                    HorizontalAlignment="Left"
                    Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock
                    x:Uid="HomePage_StarterDescription"
                    MaxWidth="300"
                    Margin="10"
                    HorizontalAlignment="Left"
                    TextWrapping="Wrap" />
                <Button
                    Margin="10"
                    HorizontalAlignment="Left"
                    Click="OpenFileButton_Click"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xED25;" />
                        <TextBlock x:Uid="HomePage_StarterOpenFile" Margin="5,0,0,0" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>

        <Grid
            Grid.Row="1"
            RowSpacing="20"
            Visibility="{x:Bind ViewModel.HasRecentDiscs, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                x:Uid="HomePage_RecentDiscs"
                Grid.Row="0"
                FontSize="20"
                FontWeight="SemiBold" />

            <ListView
                Grid.Row="1"
                ui:ScrollViewerExtensions.VerticalScrollBarMargin="0, 0, -8, 0"
                ItemsSource="{x:Bind ViewModel.RecentDiscs, Mode=OneWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:HomeRecentDiscViewModel">
                        <Grid
                            Margin="0,5"
                            Background="Transparent"
                            ColumnSpacing="20"
                            DoubleTapped="Album_DoubleTapped">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Uid="HomePage_MruOpenMenuItem" Command="{x:Bind LoadAlbumCommand, Mode=OneWay}" />
                                    <MenuFlyoutItem x:Uid="HomePage_MruRemoveMenuItem" Command="{x:Bind RemoveFromRecentCommand, Mode=OneWay}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Uid="HomePage_MruClearMenuItem" Command="{x:Bind ClearAllFromRecentCommand, Mode=OneWay}" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>

                            <Border
                                Width="48"
                                Height="48"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="{ThemeResource OverlayCornerRadius}">
                                <Grid>
                                    <FontIcon
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="32"
                                        Glyph="&#xEC4F;"
                                        Visibility="{x:Bind HasAlbumArt, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=true, Mode=OneWay}" />
                                    <Image
                                        Width="48"
                                        Height="48"
                                        Source="{x:Bind AlbumArt, Mode=OneWay}"
                                        Visibility="{x:Bind HasAlbumArt, Converter={StaticResource BoolToVisibilityConverter}, Mode=OneWay}" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="1" Orientation="Vertical">
                                <TextBlock
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind FullAlbumTitle, Mode=OneWay}"
                                    TextWrapping="NoWrap" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="12"
                                    Text="{x:Bind AlbumFilePath, Mode=OneWay}"
                                    TextWrapping="NoWrap" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button
                Grid.Row="2"
                Margin="0,10"
                HorizontalAlignment="Right"
                Click="OpenFileButton_Click">
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xED25;" />
                    <TextBlock x:Uid="HomePage_OpenFile" Margin="5,0,0,0" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
