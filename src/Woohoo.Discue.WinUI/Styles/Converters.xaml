<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ct="using:CommunityToolkit.WinUI.Converters"
    xmlns:lcl="using:Woohoo.Discue.Converters">

    <SolidColorBrush x:Key="StatusErrorColor" Color="{ThemeResource SystemErrorTextColor}" />
    <SolidColorBrush x:Key="StatusInfoColor" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="StatusSuccessColor" Color="{ThemeResource SystemFillColorSuccess}" />

    <ct:BoolNegationConverter x:Key="BoolNegationConverter" />
    <ct:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <ct:StringFormatConverter x:Key="StringFormatConverter" />

    <lcl:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    <lcl:EqualsToVisibilityConverter x:Key="EqualsToVisibilityConverter" />
    <lcl:PositionToLabelConverter x:Key="PositionToLabelConverter" />
    <lcl:AudioEngineToTextConverter x:Key="AudioEngineToTextConverter" />

</ResourceDictionary>
